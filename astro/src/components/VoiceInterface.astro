---
// components/VoiceInterface.astro
// Day 6: Full voice interface component for voice.agentsoul.dev

interface VoiceMetadata {
  original_chars: number;
  summary_chars: number;
  reduction_percent: number;
  credits_original: number;
  credits_summary: number;
  response_type: string;
}

interface ChatResponse {
  full: string;
  summary_for_tts: string;
  metadata: VoiceMetadata;
}
---

<div class="voice-interface">
  <div class="header">
    <h1>🎤 Archer Voice Interface</h1>
    <p class="subtitle">Talk to Archer while driving. Powered by summarization + ElevenLabs TTS.</p>
  </div>

  <div class="status-panel">
    <div class="status-item">
      <span class="label">Connection:</span>
      <span class="value" id="connection-status">🔄 Checking...</span>
    </div>
    <div class="status-item">
      <span class="label">Microphone:</span>
      <span class="value" id="mic-status">🔄 Checking...</span>
    </div>
    <div class="status-item">
      <span class="label">Credits Used:</span>
      <span class="value" id="credits-used">0</span>
    </div>
  </div>

  <div class="controls">
    <button id="start-btn" class="primary-btn">
      🎤 Start Recording
    </button>
    <button id="stop-btn" class="secondary-btn" disabled>
      ⏹️ Stop Recording
    </button>
  </div>

  <div class="transcription-display">
    <div class="label">Your Question:</div>
    <div id="transcription" class="text-box">(Listening...)</div>
  </div>

  <div class="response-display" id="response-display" style="display: none;">
    <div class="label">Archer's Response (Speaking):</div>
    <div id="response-text" class="text-box"></div>
    <div class="metadata">
      <span>📊 Full: <span id="meta-original">-</span> chars</span>
      <span>📉 Summary: <span id="meta-summary">-</span> chars (<span id="meta-reduction">-</span>%)</span>
      <span>💰 Credits: <span id="meta-credits">-</span></span>
    </div>
    <audio id="response-audio" controls></audio>
  </div>

  <div class="info-panel">
    <h3>ℹ️ How it works</h3>
    <ul>
      <li>Click "Start Recording" and speak your question</li>
      <li>Your speech is transcribed using Web Speech API</li>
      <li>Archer generates a response via orchestrator</li>
      <li>Response is summarized (60-75% reduction)</li>
      <li>Summary is converted to speech (ElevenLabs)</li>
      <li>Audio plays back through your device</li>
      <li>💰 Credits saved by summarization</li>
    </ul>
  </div>
</div>

<script is:inline type="module">
  import { VoiceStateMachine } from '../lib/VoiceStateMachine.ts';
  import { AndroidMicrophoneHelper } from '../lib/AndroidMicrophoneHelper.ts';
  
  console.log('VoiceInterface script loaded');
  const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
  let recognition = null;
  let stateMachine = null;
  
  const API_URL = window.location.hostname === 'localhost' ? 'http://127.0.0.1:5001' : 'https://voice.agentsoul.dev';
  
  console.log('API_URL:', API_URL);
  console.log('SpeechRecognition available:', !!SpeechRecognition);
  
  // Initialize on page load
  document.addEventListener('DOMContentLoaded', async () => {
    console.log('DOMContentLoaded fired');
    await initializeCapabilities();
    setupEventListeners();
  });

  async function initializeCapabilities() {
    console.log('Initializing capabilities...');
    
    // Show diagnostics on Android
    const diag = await AndroidMicrophoneHelper.getDiagnostics();
    console.log('Microphone Diagnostics:', diag);
    
    // Initialize state machine with wake phrase detection
    stateMachine = new VoiceStateMachine({ enableLogging: true });
    const smOk = await stateMachine.initialize();
    
    if (!smOk) {
      console.error('VoiceStateMachine initialization failed');
      
      // Show detailed diagnostic error
      const diagMessage = await AndroidMicrophoneHelper.getDiagnosticMessage();
      console.log(diagMessage);
      
      // Show permission-specific error UI
      const permStatus = diag.permissionStatus;
      if (permStatus === 'denied') {
        updateStatus('mic', '❌ Permission Denied - See settings below');
        showPermissionFixUI();
      } else {
        updateStatus('mic', '❌ Microphone unavailable');
      }
      
      updateStatus('connection', '❌ Failed to initialize');
      return;
    }
    
    // Set up state machine callbacks
    stateMachine.onStateChangeCallback((newState, oldState) => {
      console.log(`State: ${oldState} → ${newState}`);
      updateUIForState(newState);
    });

    stateMachine.onWakeDetectedCallback(() => {
      console.log('🎤 Wake phrase detected!');
      document.getElementById('transcription').textContent = '(Recording... say your question)';
      document.getElementById('transcription').style.color = '#4caf50';
    });

    stateMachine.onRecordingStartCallback(() => {
      console.log('Recording started');
      document.getElementById('start-btn').disabled = true;
      document.getElementById('stop-btn').disabled = false;
    });

    stateMachine.onRecordingEndCallback(async (text) => {
      console.log('Recording ended:', text);
      document.getElementById('start-btn').disabled = false;
      document.getElementById('stop-btn').disabled = true;
      
      if (text.trim()) {
        // Send to Archer
        await sendToArcher(text);
      }
    });

    stateMachine.onTranscriptCallback((text, isFinal) => {
      document.getElementById('transcription').textContent = text || '(Listening...)';
      stateMachine.updateTranscript(text, isFinal);
    });

    // Set up Web Speech API
    if (SpeechRecognition) {
      recognition = new SpeechRecognition();
      recognition.continuous = true;
      recognition.interimResults = true;

      recognition.onresult = (event) => {
        let interimTranscript = '';
        let finalTranscript = '';

        for (let i = event.resultIndex; i < event.results.length; i++) {
          const transcript = event.results[i][0].transcript;

          if (event.results[i].isFinal) {
            finalTranscript += transcript + ' ';
          } else {
            interimTranscript += transcript;
          }
        }

        const displayText = finalTranscript || interimTranscript;
        if (displayText) {
          stateMachine.updateTranscript(displayText, !!finalTranscript);
        }
      };

      recognition.onerror = (event) => {
        console.error('Speech recognition error:', event.error);
      };

      recognition.onend = () => {
        console.log('Recognition ended');
      };
    }

    // Check backend health
    try {
      const response = await fetch(`${API_URL}/health`);
      if (response.ok) {
        const data = await response.json();
        updateStatus('connection', '✅ Connected');
        console.log('Backend health:', data);
      }
    } catch (error) {
      console.error('Backend check failed:', error);
      updateStatus('connection', '❌ Connection failed');
    }

    updateStatus('mic', '✅ Available');
  }

  function setupEventListeners() {
    console.log('Setting up event listeners...');
    
    const startBtn = document.getElementById('start-btn');
    const stopBtn = document.getElementById('stop-btn');

    if (startBtn) {
      startBtn.addEventListener('click', () => {
        console.log('Start button clicked');
        // Manually trigger wake detection for testing
        // In production, this is automatic via AudioPipeline + WakeWordDetector
        startManualRecording();
      });
      console.log('Start button listener added');
    }

    if (stopBtn) {
      stopBtn.addEventListener('click', () => {
        console.log('Stop button clicked');
        stopManualRecording();
      });
      console.log('Stop button listener added');
    }
  }

  function startManualRecording() {
    console.log('Manual recording started');
    if (recognition) {
      recognition.start();
    }
  }

  function stopManualRecording() {
    console.log('Manual recording stopped');
    if (recognition) {
      recognition.stop();
    }
  }

  function updateUIForState(state) {
    const startBtn = document.getElementById('start-btn');
    const stopBtn = document.getElementById('stop-btn');

    switch (state) {
      case 'LISTENING':
        startBtn.disabled = false;
        stopBtn.disabled = true;
        document.getElementById('transcription').textContent = '(Say "Hey Archer" to start, or click Start)';
        document.getElementById('transcription').style.color = '#999';
        break;
      case 'RECORDING':
        startBtn.disabled = true;
        stopBtn.disabled = false;
        document.getElementById('transcription').textContent = '(Recording... say your question, end with "Go for Archer")';
        document.getElementById('transcription').style.color = '#4caf50';
        break;
      case 'PROCESSING':
        startBtn.disabled = true;
        stopBtn.disabled = true;
        document.getElementById('transcription').textContent = '(Processing...)';
        document.getElementById('transcription').style.color = '#ff9800';
        break;
      case 'TTS_PLAYBACK':
        startBtn.disabled = true;
        stopBtn.disabled = true;
        document.getElementById('transcription').textContent = '(Playing response...)';
        document.getElementById('transcription').style.color = '#4a9eff';
        break;
    }
  }

  async function sendToArcher(text) {
    console.log('Sending to Archer:', text);

    try {
      const response = await fetch(`${API_URL}/chat`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: text })
      });

      if (!response.ok) {
        throw new Error(`Chat failed: ${response.status}`);
      }

      const data = await response.json();
      console.log('Chat response:', data);

      // Process response
      await stateMachine.processChatResponse(data);
      
      // Display and play response
      displayResponse(data);
      
      // After TTS plays, return to listening
      setTimeout(() => {
        stateMachine.returnToListening();
      }, 3000);

    } catch (error) {
      console.error('Error:', error);
      updateStatus('connection', '❌ Chat failed');
    }
  }

  function displayResponse(data) {
    const responseDisplay = document.getElementById('response-display');
    const responseText = document.getElementById('response-text');

    responseText.textContent = data.summary_for_tts || data.full;
    responseDisplay.style.display = 'block';

    // Update metadata
    if (data.metadata) {
      document.getElementById('meta-original').textContent = data.metadata.original_chars;
      document.getElementById('meta-summary').textContent = data.metadata.summary_chars;
      document.getElementById('meta-reduction').textContent = data.metadata.reduction_percent;
      document.getElementById('meta-credits').textContent = (data.metadata.credits_original - data.metadata.credits_summary).toFixed(2);
      updateCreditsUsed(data.metadata.credits_summary);
    }
  }

  function updateStatus(field, value) {
    const element = document.getElementById(`${field}-status`);
    if (element) {
      element.textContent = value;
    }
  }

  function updateCreditsUsed(credits) {
    const element = document.getElementById('credits-used');
    if (element) {
      element.textContent = credits.toFixed(2);
    }
  }

  async function showPermissionFixUI() {
    const diagnosticHTML = await AndroidMicrophoneHelper.getDiagnosticHTML();
    const fixPanel = document.createElement('div');
    fixPanel.id = 'permission-fix-panel';
    fixPanel.style.cssText = `
      margin-top: 20px;
      padding: 20px;
      background: #fff3cd;
      border: 2px solid #ffc107;
      border-radius: 8px;
      font-size: 14px;
    `;
    fixPanel.innerHTML = `
      <h3 style="margin-top: 0; color: #856404;">🔧 Microphone Permission Fix</h3>
      <p><strong>Your device has denied microphone access.</strong></p>
      <h4>On Android:</h4>
      <ol>
        <li>Open <strong>Settings</strong></li>
        <li>Go to <strong>Apps</strong> (or Application Manager)</li>
        <li>Find your browser (Chrome, Firefox, etc.)</li>
        <li>Tap <strong>Permissions</strong></li>
        <li>Enable <strong>Microphone</strong></li>
        <li>Return here and refresh the page</li>
      </ol>
      <h4>On iOS:</h4>
      <ol>
        <li>Open <strong>Settings</strong></li>
        <li>Go to <strong>Privacy > Microphone</strong></li>
        <li>Enable Safari (or your browser)</li>
        <li>Refresh this page</li>
      </ol>
      <div style="margin-top: 15px; padding: 15px; background: white; border-radius: 4px; font-family: monospace; font-size: 12px; max-height: 200px; overflow-y: auto;">
        ${diagnosticHTML}
      </div>
    `;
    
    const infoPanel = document.querySelector('.info-panel');
    if (infoPanel) {
      infoPanel.parentNode.insertBefore(fixPanel, infoPanel);
    } else {
      document.querySelector('.voice-interface').appendChild(fixPanel);
    }
  }
</script>
