---
// components/VoiceInterface.astro
// Day 6: Full voice interface component for voice.agentsoul.dev

interface VoiceMetadata {
  original_chars: number;
  summary_chars: number;
  reduction_percent: number;
  credits_original: number;
  credits_summary: number;
  response_type: string;
}

interface ChatResponse {
  full: string;
  summary_for_tts: string;
  metadata: VoiceMetadata;
}
---

<div class="voice-interface">
  <div class="header">
    <h1>🎤 Archer Voice Interface</h1>
    <p class="subtitle">Talk to Archer while driving. Powered by summarization + ElevenLabs TTS.</p>
  </div>

  <div class="status-panel">
    <div class="status-item">
      <span class="label">Connection:</span>
      <span class="value" id="connection-status">🔄 Checking...</span>
    </div>
    <div class="status-item">
      <span class="label">Microphone:</span>
      <span class="value" id="mic-status">🔄 Checking...</span>
    </div>
    <div class="status-item">
      <span class="label">Credits Used:</span>
      <span class="value" id="credits-used">0</span>
    </div>
  </div>

  <div class="controls">
    <button id="start-btn" class="primary-btn">
      🎤 Start Recording
    </button>
    <button id="stop-btn" class="secondary-btn" disabled>
      ⏹️ Stop Recording
    </button>
  </div>

  <div class="transcription-display">
    <div class="label">Your Question:</div>
    <div id="transcription" class="text-box">(Listening...)</div>
  </div>

  <div class="response-display" id="response-display" style="display: none;">
    <div class="label">Archer's Response (Speaking):</div>
    <div id="response-text" class="text-box"></div>
    <div class="metadata">
      <span>📊 Full: <span id="meta-original">-</span> chars</span>
      <span>📉 Summary: <span id="meta-summary">-</span> chars (<span id="meta-reduction">-</span>%)</span>
      <span>💰 Credits: <span id="meta-credits">-</span></span>
    </div>
    <audio id="response-audio" controls></audio>
  </div>

  <div class="info-panel">
    <h3>ℹ️ How it works</h3>
    <ul>
      <li>Click "Start Recording" and speak your question</li>
      <li>Your speech is transcribed using Web Speech API</li>
      <li>Archer generates a response via orchestrator</li>
      <li>Response is summarized (60-75% reduction)</li>
      <li>Summary is converted to speech (ElevenLabs)</li>
      <li>Audio plays back through your device</li>
      <li>💰 Credits saved by summarization</li>
    </ul>
  </div>
</div>

<script is:inline>
  console.log('VoiceInterface script loaded');
  const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
  let recognition = null;
  const API_URL = window.location.hostname === 'localhost' ? 'http://127.0.0.1:5001' : 'https://voice.agentsoul.dev';
  
  console.log('API_URL:', API_URL);
  console.log('SpeechRecognition available:', !!SpeechRecognition);
  
  // Initialize on page load
  document.addEventListener('DOMContentLoaded', async () => {
    console.log('DOMContentLoaded fired');
    await initializeCapabilities();
    setupEventListeners();
  });

  async function initializeCapabilities() {
    console.log('Initializing capabilities...');
    // Check Speech API
    if (SpeechRecognition) {
      const connStatus = document.getElementById('connection-status');
      if (connStatus) connStatus.textContent = '✅ Ready';
      recognition = new SpeechRecognition();
      recognition.continuous = false;
      recognition.interimResults = true;
      recognition.onstart = () => console.log('Recognition started event');
      recognition.onend = () => console.log('Recognition ended event');
      recognition.onerror = (err) => console.error('Recognition error:', err.error);
      recognition.onresult = handleSpeechResult;
      console.log('Speech recognition ready');
      console.log('onresult handler:', recognition.onresult);
    } else {
      const connStatus = document.getElementById('connection-status');
      if (connStatus) connStatus.textContent = '❌ Not supported';
    }

    // Check microphone
    try {
      const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
      stream.getTracks().forEach(track => track.stop());
      const micStatus = document.getElementById('mic-status');
      if (micStatus) micStatus.textContent = '✅ Available';
      console.log('Microphone available');
    } catch (err) {
      const micStatus = document.getElementById('mic-status');
      if (micStatus) micStatus.textContent = '❌ Denied';
      console.log('Microphone error:', err);
    }

    // Check backend
    try {
      const resp = await fetch(`${API_URL}/health`);
      if (resp.ok) {
        const data = await resp.json();
        console.log('Backend health:', data);
        if (data.tts_ready) {
          const connStatus = document.getElementById('connection-status');
          if (connStatus) connStatus.textContent = '✅ Connected (TTS Ready)';
        }
      }
    } catch (err) {
      const connStatus = document.getElementById('connection-status');
      if (connStatus) connStatus.textContent = '❌ Backend offline';
      console.log('Backend error:', err);
    }
  }

  function setupEventListeners() {
    console.log('Setting up event listeners...');
    const startBtn = document.getElementById('start-btn');
    const stopBtn = document.getElementById('stop-btn');
    
    if (startBtn) {
      startBtn.addEventListener('click', startListening);
      console.log('Start button listener added');
    }
    if (stopBtn) {
      stopBtn.addEventListener('click', stopListening);
      console.log('Stop button listener added');
    }
  }

  function startListening() {
    console.log('startListening called');
    if (!recognition) {
      alert('Speech Recognition not supported');
      return;
    }

    const transcription = document.getElementById('transcription');
    if (transcription) transcription.textContent = '(Listening...)';
    
    const startBtn = document.getElementById('start-btn');
    const stopBtn = document.getElementById('stop-btn');
    if (startBtn) startBtn.disabled = true;
    if (stopBtn) stopBtn.disabled = false;

    recognition.start();
    console.log('Recognition started');
  }

  function stopListening() {
    console.log('stopListening called');
    if (recognition) {
      recognition.stop();
    }
    const startBtn = document.getElementById('start-btn');
    const stopBtn = document.getElementById('stop-btn');
    if (startBtn) startBtn.disabled = false;
    if (stopBtn) stopBtn.disabled = true;
  }

  function handleSpeechResult(event) {
    console.log('Speech result:', event);
    let interimTranscript = '';
    
    for (let i = event.resultIndex; i < event.results.length; i++) {
      const transcript = event.results[i][0].transcript;
      console.log('Transcript chunk:', transcript, 'isFinal:', event.results[i].isFinal);
      
      if (event.results[i].isFinal) {
        sendToArcher(transcript);
      } else {
        interimTranscript += transcript;
      }
    }
    
    if (interimTranscript) {
      const transcription = document.getElementById('transcription');
      if (transcription) transcription.textContent = interimTranscript;
    }
  }

  async function sendToArcher(text) {
    console.log('Sending to Archer:', text);
    const transcription = document.getElementById('transcription');
    if (transcription) transcription.textContent = text;
    
    try {
      const resp = await fetch(`${API_URL}/chat`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ text })
      });

      if (!resp.ok) throw new Error('Chat failed: ' + resp.status);
      
      const data = await resp.json();
      console.log('Chat response:', data);
      
      displayResponse(data);
      await playAudio(data.summary_for_tts);
      
    } catch (err) {
      console.error('Error:', err);
      const responseText = document.getElementById('response-text');
      if (responseText) responseText.textContent = `Error: ${err}`;
    }
  }

  function displayResponse(data) {
    console.log('Displaying response');
    const display = document.getElementById('response-display');
    if (display) display.style.display = 'block';
    
    const responseText = document.getElementById('response-text');
    if (responseText) responseText.textContent = data.summary_for_tts;
    
    const metaOriginal = document.getElementById('meta-original');
    if (metaOriginal) metaOriginal.textContent = data.metadata.original_chars.toString();
    
    const metaSummary = document.getElementById('meta-summary');
    if (metaSummary) metaSummary.textContent = data.metadata.summary_chars.toString();
    
    const metaReduction = document.getElementById('meta-reduction');
    if (metaReduction) metaReduction.textContent = data.metadata.reduction_percent.toString();
    
    const metaCredits = document.getElementById('meta-credits');
    if (metaCredits) metaCredits.textContent = 
      `${data.metadata.credits_original} → ${data.metadata.credits_summary}`;
    
    const creditsUsed = document.getElementById('credits-used');
    if (creditsUsed) {
      const current = parseInt(creditsUsed.textContent || '0');
      creditsUsed.textContent = (current + data.metadata.credits_summary).toString();
    }
  }

  async function playAudio(text) {
    console.log('Playing audio for:', text);
    try {
      const ttsResp = await fetch(`${API_URL}/tts`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ text })
      });

      if (!ttsResp.ok) throw new Error('TTS failed: ' + ttsResp.status);
      
      const audioBlob = await ttsResp.blob();
      const audioUrl = URL.createObjectURL(audioBlob);
      
      const audioElement = document.getElementById('response-audio');
      if (audioElement) {
        audioElement.src = audioUrl;
        audioElement.play();
      }
      
    } catch (err) {
      console.error('Audio playback error:', err);
    }
  }
</script>

<style>
  .voice-interface {
    max-width: 700px;
    margin: 0 auto;
    padding: 40px 20px;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }

  .header {
    text-align: center;
    margin-bottom: 40px;
  }

  .header h1 {
    font-size: 32px;
    color: #00d9ff;
    margin-bottom: 10px;
  }

  .subtitle {
    color: #aaa;
    font-size: 14px;
  }

  .status-panel {
    background: rgba(0, 217, 255, 0.05);
    border: 1px solid #00d9ff;
    border-radius: 8px;
    padding: 16px;
    margin-bottom: 20px;
    display: flex;
    justify-content: space-around;
    flex-wrap: wrap;
    gap: 16px;
  }

  .status-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .status-item .label {
    color: #00d9ff;
    font-size: 12px;
    font-weight: 600;
  }

  .status-item .value {
    color: #fff;
    font-size: 14px;
  }

  .controls {
    display: flex;
    gap: 10px;
    margin-bottom: 30px;
  }

  .primary-btn,
  .secondary-btn {
    flex: 1;
    padding: 16px;
    font-size: 16px;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-weight: 600;
    transition: all 0.3s;
  }

  .primary-btn {
    background: #00d9ff;
    color: #000;
  }

  .primary-btn:hover:not(:disabled) {
    background: #00ffff;
    transform: scale(1.02);
  }

  .primary-btn:disabled {
    opacity: 0.5;
  }

  .secondary-btn {
    background: #ff0055;
    color: #fff;
  }

  .secondary-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .transcription-display,
  .response-display {
    margin-bottom: 24px;
  }

  .label {
    color: #00d9ff;
    font-size: 12px;
    font-weight: 600;
    margin-bottom: 8px;
  }

  .text-box {
    background: rgba(0, 0, 0, 0.5);
    border: 1px solid #00d9ff;
    border-radius: 8px;
    padding: 16px;
    min-height: 60px;
    color: #fff;
    font-family: monospace;
    font-size: 14px;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .metadata {
    display: flex;
    justify-content: space-between;
    margin-top: 12px;
    padding-top: 12px;
    border-top: 1px solid rgba(0, 217, 255, 0.2);
    color: #aaa;
    font-size: 12px;
    font-family: monospace;
  }

  audio {
    width: 100%;
    margin-top: 12px;
  }

  .info-panel {
    background: rgba(0, 217, 255, 0.05);
    border: 1px solid #00d9ff;
    border-radius: 8px;
    padding: 20px;
    margin-top: 40px;
  }

  .info-panel h3 {
    color: #00d9ff;
    margin-bottom: 12px;
    font-size: 16px;
  }

  .info-panel ul {
    list-style: none;
    padding: 0;
  }

  .info-panel li {
    color: #aaa;
    font-size: 14px;
    margin-bottom: 8px;
  }

  @media (max-width: 600px) {
    .header h1 {
      font-size: 24px;
    }

    .status-panel {
      flex-direction: column;
      gap: 12px;
    }

    .controls {
      flex-direction: column;
    }
  }
</style>
